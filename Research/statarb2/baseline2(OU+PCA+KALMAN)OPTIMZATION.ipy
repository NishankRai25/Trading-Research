    "\n",
    "# Pretty plots\n",
    "plt.figure(figsize=(11, 5))\n",
    "cum_returns.plot(linewidth=1.8)\n",
    "plt.title(\"Equity Curve\")\n",
    "plt.xlabel(\"Date\")\n",
    "plt.ylabel(\"Cumulative Return\")\n",
    "plt.show()\n",
    "\n",
    "plt.figure(figsize=(11, 5))\n",
    "drawdown.plot(linewidth=1.5)\n",
    "plt.title(\"Drawdown\")\n",
    "plt.xlabel(\"Date\")\n",
    "plt.ylabel(\"Drawdown\")\n",
    "plt.show()\n",
    "\n",
    "plt.figure(figsize=(11, 5))\n",
