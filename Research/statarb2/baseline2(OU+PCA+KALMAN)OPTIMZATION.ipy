   ],
   "source": [
    "# Build Rolling 1 Year windows\n",
    "valid_dates = returns.index[PCA_LOOKBACK:]\n",
    "print(\"Number of trading days:\", len(returns))\n",
    "print(\"Number of valid PCA dates:\", len(valid_dates))\n",
    "print(\"First PCA date:\", valid_dates[0])"
