   "source": [
    "import optuna\n",
    "import numpy as np\n",
    "\n",
    "# =========================\n",
    "# OBJECTIVE FUNCTION\n",
    "# =========================\n",
    "def objective(trial):\n",
    "\n",
    "    # -------------------------\n",
    "    # SAMPLE PARAMETERS\n",
    "    # -------------------------\n",
    "    ENTRY = trial.suggest_float(\"ENTRY\", 1.0, 2.0)\n",
    "    L_EXIT = trial.suggest_float(\"L_EXIT\", 0.1, 0.5)\n",
    "    S_EXIT = trial.suggest_float(\"S_EXIT\", 0.3, 0.8)\n",
    "\n",
    "    KAPPA = trial.suggest_int(\"KAPPA\", 5, 20)\n",
    "    PCA_F = trial.suggest_int(\"PCA\", 3, 10)\n",
    "\n",
    "    DELTA_A = trial.suggest_float(\"DELTA_A\", 0.97, 0.999)\n",
    "    DELTA_B = trial.suggest_float(\"DELTA_B\", 0.90, 0.99)\n",
    "\n",
    "    # -------------------------\n",
    "    # SET GLOBAL PARAMS\n",
    "    # -------------------------\n",
    "    global ENTRY_THRESHOLD, LONG_EXIT_THRESHOLD, SHORT_EXIT_THRESHOLD\n",
    "    global KAPPA_MIN, N_PCA_FACTORS, delta_A, delta_B\n",
    "\n",
    "    ENTRY_THRESHOLD = ENTRY\n",
    "    LONG_EXIT_THRESHOLD = L_EXIT\n",
    "    SHORT_EXIT_THRESHOLD = S_EXIT\n",
    "    KAPPA_MIN = KAPPA\n",
    "    N_PCA_FACTORS = PCA_F\n",
    "    delta_A = DELTA_A\n",
    "    delta_B = DELTA_B\n",
    "\n",
    "    # -------------------------\n",
    "    # STATE\n",
    "    # -------------------------\n",
    "    pnl_series = []\n",
    "    positions = {}\n",
    "    weights_prev = {}\n",
    "    kf_state = {}\n",
    "\n",
    "    # -------------------------\n",
    "    # BACKTEST LOOP\n",
    "    # -------------------------\n",
    "    for step, i in enumerate(valid_pos):\n",
    "\n",
    "        snapshot = build_rolling_snapshot(i)\n",
    "\n",
    "        if snapshot is None:\n",
    "            pnl_series.append(0.0)\n",
    "            continue\n",
    "\n",
    "        s_values = {}\n",
    "        beta_dict = {}\n",
    "\n",
    "        valid_names = snapshot[\"valid_col_names\"]\n",
    "\n",
    "        for j, stock in enumerate(valid_names):\n",
    "\n",
    "            s, betas, _ = compute_stock_signal(\n",
    "                j, stock, snapshot, kf_state, None\n",
    "            )\n",
    "\n",
    "            if s is not None and betas is not None:\n",
    "                s_values[stock] = s\n",
    "                beta_dict[stock] = betas\n",
    "\n",
    "        if not s_values:\n",
    "            pnl_series.append(0.0)\n",
    "            positions.clear()\n",
    "            weights_prev.clear()\n",
    "            continue\n",
    "\n",
    "        positions = update_positions(positions, s_values)\n",
    "\n",
    "        weights, _, _, _ = build_target_weights(positions, beta_dict)\n",
    "\n",
    "        pnl = compute_one_day_pnl(i, snapshot, weights)\n",
    "\n",
    "        if pnl is None:\n",
    "            continue\n",
    "\n",
    "        pnl_series.append(pnl)\n",
    "\n",
    "        weights_prev = weights.copy()\n",
    "\n",
    "        # -------------------------\n",
    "        # PRUNING (KEY SPEED BOOST)\n",
    "        # -------------------------\n",
    "        if step > 200:\n",
    "            pnl_arr = np.array(pnl_series)\n",
    "\n",
    "            if len(pnl_arr) > 50:\n",
    "                ret = pnl_arr.mean() * 252\n",
    "                vol = pnl_arr.std() * np.sqrt(252)\n",
    "\n",
    "                if vol > 0:\n",
    "                    sharpe = ret / vol\n",
    "                    trial.report(sharpe, step)\n",
    "\n",
    "                    # kill bad trials early\n",
    "                    if trial.should_prune():\n",
    "                        raise optuna.exceptions.TrialPruned()\n",
    "\n",
    "    # -------------------------\n",
    "    # FINAL METRICS\n",
    "    # -------------------------\n",
    "    pnl_arr = np.array(pnl_series)\n",
    "\n",
    "    if len(pnl_arr) < 200:\n",
    "        return -1\n",
    "\n",
    "    ret = pnl_arr.mean() * 252\n",
    "    vol = pnl_arr.std() * np.sqrt(252)\n",
    "\n",
    "    if vol == 0:\n",
    "        return -1\n",
    "\n",
    "    sharpe = ret / vol\n",
    "\n",
    "    return sharpe\n",
    "\n",
    "\n",
    "# =========================\n",
    "# RUN OPTIMIZATION\n",
    "# =========================\n",
    "study = optuna.create_study(\n",
    "    direction=\"maximize\",\n",
    "    sampler=optuna.samplers.TPESampler(),\n",
    "    pruner=optuna.pruners.MedianPruner(n_warmup_steps=5)\n",
    ")\n",
    "\n",
    "study.optimize(objective, n_trials=40)\n",
    "\n",
    "# =========================\n",
    "# RESULTS\n",
    "# =========================\n",
    "print(\"\\n=== BEST PARAMS ===\")\n",
    "print(study.best_params)\n",
    "\n",
    "print(\"\\n=== BEST SHARPE ===\")\n",
    "print(study.best_value)"
   ]
  }
 ],
